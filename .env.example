# Copy to `.env` / `.env.local` for Vite (not used by Pages Functions).
#
# Set to `true` to require username/password before `/app` (needs AUTH_JWT_SECRET + D1 auth_users on the API).
# VITE_REQUIRE_AUTH=true

# --- Railway migration (Wave RM-α onwards) ---
# Local dev Postgres. The docker-compose.dev.yml defaults use sonic/sonic
# credentials — see docs/RAILWAY-KICKOFF.md "Local dev setup" for the
# exact connection string. Pentest M-20: do NOT commit real credentials
# to this file; the placeholder below is intentionally non-functional.
DATABASE_URL=postgresql://<DB_USER>:<DB_PASS>@localhost:5432/<DB_NAME>

# --- Production-only env vars (set on Railway, never here) ---
# AUTH_JWT_SECRET=                           # HS256 session signing key (≥32 bytes)
# STRIPE_WEBHOOK_SECRET=                     # whsec_… from Stripe dashboard
# STORAGE_ENDPOINT_URL=                      # https://<account>.r2.cloudflarestorage.com
# STORAGE_BUCKET=sonic-bloom-media
# STORAGE_ACCESS_KEY_ID=                     # from Cloudflare R2 "Manage API tokens"
# STORAGE_SECRET_ACCESS_KEY=
# STREAM_CONTROL_URL=                        # AzuraCast etc. — optional, Wave γ+
# STREAM_CONTROL_KEY=
# OPENAI_API_KEY=                            # AI providers — optional, Wave β7+
# ELEVENLABS_API_KEY=
# AI_AUDIO_URL_ALLOWED_HOSTS=                # comma-separated suffixes for SSRF allowlist (M-13)
