{
  "name": "sonic-bloom",
  "private": true,
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KunanonJ/radio-development.git"
  },
  "bugs": {
    "url": "https://github.com/KunanonJ/radio-development/issues"
  },
  "homepage": "https://github.com/KunanonJ/radio-development#readme",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:share": "next dev -p 3010",
    "dev:e2e": "next dev -p 3330",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "verify": "npm run lint && npm test && npm run test:migrations && npm run test:e2e && npm run build",
    "test": "vitest run --project=node",
    "test:ui": "vitest run --project=jsdom",
    "test:all": "vitest run",
    "test:migrations": "vitest run --config vitest.migrations.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "emulators:start": "npx firebase emulators:start --only auth,firestore,storage,ui",
    "deploy:firebase": "npx firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:firebase:storage": "npx firebase deploy --only storage",
    "deploy:apphosting": "npx firebase deploy --only apphosting:urban-radio-web",
    "pages:dev": "node scripts/pages-dev-hint.mjs",
    "pages:deploy": "node scripts/pages-deploy.mjs",
    "pages:upload": "node scripts/pages-deploy.mjs",
    "deploy": "node scripts/pages-deploy.mjs",
    "cf:pages:list": "wrangler pages project list",
    "db:seed:build": "node scripts/build-d1-seed.mjs",
    "db:migrate:local": "wrangler d1 migrations apply sonic-bloom-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply sonic-bloom-db --remote",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:sync-from-d1": "node scripts/migrate-d1-to-pg.mjs",
    "backup": "node scripts/backup-d1-to-r2.mjs",
    "backup:pg": "node scripts/backup-pg-to-s3.mjs",
    "janitor:r2": "node scripts/janitor-r2-orphans.mjs"
  },
  "overrides": {
    "protobufjs": ">=7.5.6",
    "@grpc/grpc-js": ">=1.13.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.24",
    "@tremor/react": "3.18.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "0.45.2",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^11.9.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "input-otp": "^1.4.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.462.0",
    "next": "^16.2.6",
    "next-themes": "^0.3.0",
    "pg": "8.20.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.61.1",
    "react-i18next": "^17.0.2",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "rrule": "2.8.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20250402.0",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.16.5",
    "@types/pg": "8.20.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.32.0",
    "eslint-config-next": "15.5.9",
    "globals": "^15.15.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.1",
    "pg-mem": "3.0.14",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.103.0"
  }
}
